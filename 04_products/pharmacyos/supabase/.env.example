# Supabase Edge Function secrets (template — never commit real values)
# Copy to supabase/.env and fill in for local development of Edge Functions.
# Production values are set via: supabase secrets set KEY=value

# Anthropic Claude Vision API (server-side only — invoice + Rx scanning)
ANTHROPIC_API_KEY=

# Lynk payment processing (server-side only)
LYNK_API_KEY=
LYNK_API_SECRET=

# Note: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# injected automatically by the Supabase Edge Function runtime — do not set them here.
