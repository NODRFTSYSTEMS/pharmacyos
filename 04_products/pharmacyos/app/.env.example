# PharmacyOS — frontend environment variables (template)
# Copy to .env.local (gitignored) and fill in real values from the Supabase dashboard.
# Project Settings → API → Project URL and anon public key.
#
# Rule (ADR Decision 11): only public-safe values may live in VITE_* keys.
# Secret credentials (Anthropic, Lynk, service_role) belong in Supabase Edge Function secrets only.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Demo mode — enables the acting-role switcher in the sidebar so reviewers can
# verify the permissions matrix as any role. Set to 'false' or omit in production.
VITE_DEMO_MODE=true
