# CasaClaro — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Data mode ──────────────────────────────────────────────────────────────────
# Controls whether listings come from seed data or a live database.
NEXT_PUBLIC_LISTINGS_MODE=synthetic

# ── Analytics ──────────────────────────────────────────────────────────────────
# Plausible Analytics — set to your domain to activate the tracking script.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=casaclaro.co

# ── Email notifications ────────────────────────────────────────────────────────
# Resend API key — enables email notifications on waitlist + contact form submissions.
# RESEND_API_KEY=re_xxxxxxxxxx
# CASACLARO_NOTIFY_EMAIL=hello@casaclaro.co

# ── Supabase (future sprint) ───────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
