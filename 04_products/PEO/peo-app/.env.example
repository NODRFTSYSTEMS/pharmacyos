# PEO Environment Configuration
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local to version control.

# ─── Database — Neon PostgreSQL ──────────────────────────────────────────────
# 1. Create a project at https://neon.tech
# 2. Copy the connection string from your Neon dashboard
# 3. After setting this, run: pnpm prisma migrate deploy
# Neon format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk Authentication ────────────────────────────────────────────────────
# 1. Create an application at https://dashboard.clerk.com
# 2. Copy keys from Clerk dashboard → API Keys
# Sign-in/sign-up routes must match NEXT_PUBLIC_CLERK_SIGN_IN_URL below
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/en/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/en/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/en"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/en"

# ─── PostHog Analytics ───────────────────────────────────────────────────────
# Create a project at https://posthog.com (free tier sufficient to start)
NEXT_PUBLIC_POSTHOG_KEY="phc_replace_me"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─── Rentcast Property Data API ──────────────────────────────────────────────
# Get from https://rentcast.io/api
# ⚠️ Rotate this key if it has ever appeared in git history
RENTCAST_API_KEY="your_rentcast_api_key_here"

# ─── Resend Email ────────────────────────────────────────────────────────────
# Create an account at https://resend.com, add and verify your sending domain
# Set RESEND_FROM_EMAIL to a verified address on your domain
RESEND_API_KEY="re_replace_me"
RESEND_FROM_EMAIL="hello@yourdomain.com"

# ─── Development Overrides ───────────────────────────────────────────────────
# Local dev only. Both NODE_ENV=development AND this flag must be set.
# Never set to true in production — the app checks NODE_ENV at runtime.
# ENABLE_DEV_BYPASS="true"
