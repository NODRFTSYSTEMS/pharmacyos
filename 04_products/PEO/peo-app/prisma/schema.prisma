// PEO Prisma Schema — Phase 1 Skeleton
// Single source of truth for data shape. No ad hoc SQL without RCA + DSS review.
// Provider: PostgreSQL (Neon serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  anonymous_visitor
  free_user
  seller_applicant
  seller_verified
  investor_basic
  investor_advanced
  vendor
  admin_internal
}

enum Language {
  en_US
  es_US
}

enum ConfidenceTier {
  HIGH
  MEDIUM
  LOW
  VERY_LOW
}

enum ApplicationStatus {
  draft
  submitted
  in_review
  triage_complete
  ready
  closed
}

enum ApplicationContext {
  seller_application
  investor_basic_analysis
  investor_advanced_analysis
}

enum VendorStatus {
  pending
  verified
  suspended
}

enum AuditActionType {
  export_download
  triage_view
  readiness_view
  admin_action
  formula_override
  kill_switch_trigger
  confidence_review_trigger
  role_change
  upload_create
  application_submit
}

// ─── Core Identity ───────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  email         String   @unique
  role          UserRole @default(free_user)
  preferredLang Language @default(en_US)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions           Session[]
  consents           ConsentRecord[]
  estimatorSessions  EstimatorSession[]
  sellerApplications SellerApplication[]
  investorProfile    InvestorProfile?
  vendor             Vendor?
  auditLogs          AuditLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String?
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ConsentRecord {
  id          String   @id @default(uuid())
  userId      String
  version     String
  terms       Boolean
  privacy     Boolean
  marketing   Boolean
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_records")
}

// ─── Estimator (Free Tier) ───────────────────────────────

model EstimatorSession {
  id        String   @id @default(uuid())
  userId    String?
  mode      String   // "seller" | "investor"
  inputs    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  results EstimatorResult[]

  @@map("estimator_sessions")
}

model EstimatorResult {
  id             String   @id @default(uuid())
  estimatorSessionId String
  formulaVersion String
  outputs        Json
  labels         Json     // bilingual labels for display
  createdAt      DateTime @default(now())

  estimatorSession EstimatorSession @relation(fields: [estimatorSessionId], references: [id], onDelete: Cascade)

  @@map("estimator_results")
}

// ─── Seller Application (Deal Record) ────────────────────

model SellerApplication {
  id                String              @id @default(uuid())
  userId            String
  context           ApplicationContext  @default(seller_application)
  status            ApplicationStatus   @default(draft)
  address           String
  addressConfirmed  Boolean             @default(false)
  goals             Json?
  timeline          String?
  propertyFacts     Json?
  investorInputs    Json?
  expectedSalePrice Decimal?            @db.Decimal(14, 2)
  mortgagePayoff    Decimal?            @db.Decimal(14, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads    UploadArtifact[]
  triage     TriageResult?
  readiness  ReadinessPlan?
  rehabItems RehabItem[]

  @@index([userId])
  @@map("seller_applications")
}

model UploadArtifact {
  id          String   @id @default(uuid())
  applicationId String
  fileName    String
  contentType String
  r2Key       String
  signedUrl   String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  application SellerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("upload_artifacts")
}

// ─── Triage Engine ───────────────────────────────────────

model TriageResult {
  id              String         @id @default(uuid())
  applicationId   String         @unique
  engineVersion   String
  formulaVersion  String
  confidenceScore Int
  confidenceTier  ConfidenceTier
  flags           Json           // array of triggered flags
  recommendation  String?
  passTriggered   Boolean        @default(false)
  investorOutputs Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  application SellerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("triage_results")
}

model RehabItem {
  id                 String   @id @default(uuid())
  applicationId      String
  category           String
  description        String?
  quantity           Decimal  @db.Decimal(10, 2) @default(dbgenerated("1"))
  unitCost           Decimal  @db.Decimal(14, 2) @default(dbgenerated("0"))
  regionalMultiplier Decimal  @db.Decimal(5, 2) @default(dbgenerated("1.0"))
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  application SellerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("rehab_items")
}

// ─── Readiness ───────────────────────────────────────────

model ReadinessPlan {
  id               String   @id @default(uuid())
  applicationId    String   @unique
  taxonomyVersion  String
  summary          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application SellerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  items       ReadinessItem[]

  @@map("readiness_plans")
}

model ReadinessItem {
  id            String    @id @default(uuid())
  planId        String
  category      String
  title         String
  description   String?
  estimatedCost Decimal?  @db.Decimal(14, 2)
  priority      Int       @default(0)
  completed     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan ReadinessPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("readiness_items")
}

// ─── Investor ────────────────────────────────────────────

model InvestorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  strategy      String?  // e.g., "fix_and_flip", "buy_and_hold", "wholesale"
  markets       String[] // array of market identifiers
  preferences   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_profiles")
}

// ─── Marketplace ─────────────────────────────────────────

model Vendor {
  id          String       @id @default(uuid())
  userId      String       @unique
  status      VendorStatus @default(pending)
  companyName String
  services    String[]
  markets     String[]
  website     String?
  bio         String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads  VendorLead[]
  reviews Review[]

  @@map("vendors")
}

model VendorLead {
  id        String   @id @default(uuid())
  vendorId  String
  source    String   // e.g., "seller_app", "investor_basic", "investor_advanced"
  payload   Json     // PII-safe lead summary
  contacted Boolean  @default(false)
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_leads")
}

model Review {
  id        String   @id @default(uuid())
  vendorId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─── Audit & Compliance ──────────────────────────────────

model AuditLog {
  id        String          @id @default(uuid())
  userId    String?
  action    AuditActionType
  resource  String          // table/endpoint affected
  resourceId String?
  meta      Json?
  createdAt DateTime        @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
